{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && cross-env SESSION_COOKIE=medai_session_gp NEXT_DIST_DIR=.next-gp next dev -p 3000",
    "dev:specialist": "prisma generate && cross-env SESSION_COOKIE=medai_session_spec NEXT_DIST_DIR=.next-spec next dev -p 3001",
    "start:gp": "cross-env SESSION_COOKIE=medai_session_gp next start -p 3000",
    "start:specialist": "cross-env SESSION_COOKIE=medai_session_spec next start -p 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "pdf-parse": "^2.4.5",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
